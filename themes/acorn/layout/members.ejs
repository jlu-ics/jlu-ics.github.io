<div class="container">
  <%- partial('_partial/page/banner') %>
  <%# partial('_partial/page/heading') %>
  <% post = page %>
  <% index = false %>

<article id="<%= post.layout %>-<%= post.slug %>" class="article article-type-<%= post.layout %>" itemprop="blogPost" itemscope itemtype="https://schema.org/BlogPosting">
  <% if (post.excerpt && index){ %>
  <div class="card rounded">
    <%- partial('_partial/post/gallery') %>
    <div class="card-body bg-light">
			<%- partial('_partial/post/title', {class_name: 'article-title mb-0 line-clamp line-clamp-1'}) %>
			<%- partial('_partial/post/date', {class_name: 'article-date', date_format: null}) %>
			<div class="card-text mt-3 line-clamp line-clamp-2"><%- post.excerpt %></div>
      <hr class="hr">
      <% if (theme.excerpt_link){ %>
      <div class="article-more-link">
        <a href="<%- url_for(post.path) %>#more"><%= theme.excerpt_link %></a>
      </div>
      <% } %>
    </div>
  </div>
  <% } else { %>
  <% if (is_post()) { %>
  <div class="article-cover mb-5">
    <%- partial('_partial/post/gallery') %>
  </div>
  <% } %>
  <div class="article-inner">
    <% if (post.link || post.title){ %>
    <header class="article-header">
      <% if (!is_page()) { %>
      <%- partial('_partial/post/title', {class_name: 'article-title'}) %>
      <div class="article-meta">
        <%- partial('_partial/post/date', {class_name: 'article-date', date_format: null}) %>
        <%- partial('_partial/post/category') %>
      </div>
      <% } %>
    </header>
    <% } %>
    <div class="article-entry" itemprop="articleBody">

      <% for (var i in post.data) { %>
        <% var sec = post.data[i] %>

        <h2><%= sec.section %></h2>
        <div class="members-container">

          <% for (var j in sec.sub) { %>
            <% member = sec.sub[j] %>

            <div class="member <% if (!member.picture) { %>nopic<% } %> <% if (member.note2) { %>ln4<% } %>">
              <% if (member.picture) { %>
              <div class="member-avatar">
                <img src="<%= url_for(member.picture) %>" alt="<%= member.name %>">
              </div>
              <% } %>
              <div class="member-info"
                <% if (!member.picture) { %>
                  style="text-align: center;"
                <% } %>
              >
                <h5>
                  <a <% if (member.link) { %> href="<%= url_for(member.link) %>" <% if (member.link.startsWith('http')) {
                      %>target="_blank"<%
                    } %> <% } %>><%= member.name %></a>
                </h5>
                <p class="subtitle"><%- member.subtitle %></p>
                <p class="note"><%- member.note %></p>
                <% if (member.note2) { %><p class="note"><%- member.note2 %></p><% } %>
              </div>
            </div>

          <% } %>

      </div>
      <% } %>

      <style>
        .article-entry .members-container {
          display: flex;
          flex-direction: row;
          flex-wrap: wrap;
          justify-content: left;
        }
        .article-entry .member-avatar {
          height: 12rem;
          width: 9rem;
          overflow: hidden;
          margin: 1rem;
        }
        .article-entry .member-info {
          overflow: hidden;
          margin: 1rem;
          flex: min-content;
        }
        .article-entry .member-info h5 {
          margin: 0.2rem;
        }
        .article-entry .member-info .subtitle {
          margin: 0.2rem;
        }
        .article-entry .member-info .note {
          color: #626262;
          margin: 0.2rem;
        }
        .article-entry img {
          width: 100%;
          height: 100%;
          object-fit: cover;
        }
        .article-entry .member {
          background-color: ghostwhite;
          height: 14rem;
          width: 25rem;
          margin: 1em;
          display: flex;
          flex-direction: row;
        }
        .member.nopic {
          width: 16rem;
          height: 12rem;
        }
        .member.ln4 p {
          line-height: 1.2rem;
        }
      </style>

    </div>
    <footer class="article-footer">
      <%- partial('_partial/post/tag') %>
    </footer>
  </div>
  <% } %>
  <% if (!index){ %>
    <%- partial('_partial/post/nav') %>
  <% } %>
</article>

</div>