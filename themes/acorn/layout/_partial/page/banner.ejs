<div class="banner mb-5"
style="background-image: url(<% if (page.banner) {
  %><%- url_for(page.banner) %><%
  } else {
  %><%- url_for(theme.hero.image) %><% } %>)">
  <div class="banner-text text-center">
    <!-- page-type-title -->
    <% if (!is_post()) { %>
      <%- partial('title') %>
    <% } %>
    <!-- page-type-slogan -->
    <h4 class="slogan font-w-lighter">
    <% if (page.subtitle) { %>
      <%- page.subtitle %>
    <% } else if (is_archive()) { %>
      <%- theme.slogan.archives %>
    <% } else if (is_page()) { %>
      <%- theme.slogan.pages %>
    <% } else {%>
      <%- theme.slogan.posts %>
    <% } %>
    </h4>
  </div>
</div>